#############################################################
# Matchfile: fastlane match 설정 - 인증서 및 프로비저닝 관리
#############################################################

# TODO: 인증서와 프로비저닝 프로파일을 저장할 비공개 Git 레포 URL로 교체하세요.
# - 권장: 비공개 레포 (예: SSH 방식 git@github.com:org/certificates-ios.git)
# - CI에서는 GitHub Secrets의 MATCH_GIT_URL 또는 MATCH_GIT_URL_SSH로 주입하세요.
# - SSH 사용 시 MATCH_SSH_PRIVATE_KEY, Deploy Key, known_hosts 설정이 필요합니다.
git_url(ENV["MATCH_GIT_URL"] || ENV["MATCH_GIT_URL_SSH"] || "https://github.com/Haesus/certificates-ios.git")

# TODO: 인증서 저장소의 브랜치명으로 교체하세요.
git_branch(ENV["MATCH_GIT_BRANCH"] || "master")

# 저장 방식
# - 기본값: "git"
# - 다른 옵션으로는 google_cloud, s3 등이 있음
# - 저장소 타입에 따라 인증서 및 프로비저닝 프로파일을 어디에 저장할지 결정
storage_mode("git")

# 인증서 종류
# - appstore: 앱스토어 배포용 (기본값)
# - development: 개발용 인증서 및 프로파일
# - adhoc: 테스트 기기 등록용 (내부 테스트용)
# - enterprise: 엔터프라이즈 배포용
# - 이 값에 따라 생성/관리되는 인증서 및 프로비저닝 프로파일 유형이 결정됨
type("appstore")

# TODO: AppEnv.bundleId의 DEV/BETA/RELEASE 값과 동일하게 교체하세요.
# - App Store Connect 및 Apple Developer Identifiers에 등록된 앱 ID와 일치해야 합니다.
# - 예: ["com.company.myapp", "com.company.myapp.beta", "com.company.myapp.dev"]
app_identifier([
  "dev.tuist.SwiftCICD",
  "dev.tuist.SwiftCICD.beta",
  "dev.tuist.SwiftCICD.dev"
])

# TODO: Apple Developer Portal 로그인 이메일로 교체하거나 ENV로 바꾸세요.
# - match가 Apple Developer Portal에 접근할 때 사용합니다.
# - App Store Connect API Key와는 별개의 계정 정보입니다.
# - 예: ENV["FASTLANE_APPLE_ID"] || "developer@company.com"
username("sea15510@icloud.com")

# 해당 부분은 팀원들이 프로파일을 가져올때 사용할 명령어
# fastlane match development --readonly
# fastlane match appstore --readonly

# 참고:
# - 추가 옵션 및 상세 설정은 `fastlane match --help` 명령어로 확인 가능
# - 공식 문서: https://docs.fastlane.tools/actions/match
